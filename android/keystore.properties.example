# Example keystore.properties for release builds.
# Copy this file to android/keystore.properties and fill in your values.
# DO NOT commit the real keystore.properties to git — it contains passwords.
#
# Generate a release keystore with:
#   keytool -genkeypair -v \
#     -keystore release.keystore \
#     -alias obsidian-tools \
#     -keyalg RSA -keysize 4096 \
#     -validity 10000

storeFile=/absolute/path/to/release.keystore
storePassword=your-store-password
keyAlias=obsidian-tools
keyPassword=your-key-password
