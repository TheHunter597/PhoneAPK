{
  "name": "obsidian-server-android",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone Android APK wrapping the Obsidian Tools Node.js server via nodejs-mobile-react-native",
  "scripts": {
    "android": "react-native run-android",
    "android:build-apk": "cd android && ./gradlew assembleRelease",
    "android:build-debug": "cd android && ./gradlew assembleDebug",
    "android:clean": "cd android && ./gradlew clean",
    "start": "react-native start",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.1",
    "@react-native-documents/picker": "12.0.1",
    "@img/sharp-wasm32": "0.35.2",
    "nodejs-mobile-react-native": "18.20.4",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-webview": "^13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/runtime": "^7.28.0",
    "@react-native-community/cli": "20.1.2",
    "@react-native-community/cli-platform-android": "20.1.2",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/react": "^19.2.0",
    "babel-jest": "^30.0.0",
    "eslint": "^8.57.0",
    "jest": "^30.0.0",
    "metro-react-native-babel-preset": "0.77.0",
    "prettier": "2.8.8",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
